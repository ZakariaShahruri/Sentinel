#pragma once

// Unique ID for this node — each physical node gets a different value.
// Must be between 0x01 and 0xFE. Used in the RF header and AES nonce.
#define NODE_ID 0x01

#define AES_KEY_BYTES { \
    0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, \
    0x08, 0x09, 0x0A, 0x0B, 0x0C, 0x0D, 0x0E, 0x0F \
}
